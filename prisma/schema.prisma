datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Prescription {
  id                 String   @id @default(uuid())
  patientName        String
  patientDob         String
  patientPhone       String
  patientAddress     String
  prescriberName     String
  prescriberLicense  String
  prescriberDea      String?
  drugName           String
  genericName        String?
  brandName          String?
  strengthValue      Float
  strengthUnit       String
  dosageForm         String
  quantityValue      Float
  quantityUnit       String
  sig                String
  refillsAuthorized  Int
  controlledSchedule String?
  status             String   @default("created")
  signedAt           DateTime
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  events             Event[]
}

model Event {
  id             String       @id @default(uuid())
  prescriptionId String
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  type           String
  actorRole      String
  actorId        String
  payload        String
  createdAt      DateTime     @default(now())
}
